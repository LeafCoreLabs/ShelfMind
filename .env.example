# Database (via PgBouncer)
DATABASE_URL=postgresql+asyncpg://shelfmind:shelfmind@pgbouncer:5432/shelfmind
DATABASE_URL_SYNC=postgresql://shelfmind:shelfmind@pgbouncer:5432/shelfmind

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# MinIO (S3-compatible)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=shelfmind-reports

# Groq AI (recommended — powers NL queries and admin copilot)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# OpenAI (optional fallback if Groq key not set)
OPENAI_API_KEY=

# Weather — uses each store's lat/lon from Shop Profile
# Open-Meteo is free (no key). Optional OpenWeather for richer data:
OPENWEATHER_API_KEY=
GOOGLE_TRENDS_ENABLED=false
META_GRAPH_TOKEN=

# Optional — Cloudflare R2 (free S3-compatible storage for report exports)
# S3_ENABLED=true
# S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=shelfmind-reports

# App
STORE_LAT=19.0760
STORE_LON=72.8777
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Comma-separated frontend URLs (add your Vercel/custom domain)
CORS_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:5173,https://shelf-mind-mu.vercel.app

# Local Docker: MinIO + separate Celery containers (docker-compose.yml)
EMBED_CELERY=false
S3_ENABLED=true

# Free Render deploy: embedded Celery, no MinIO
# EMBED_CELERY=true
# S3_ENABLED=false
